{
    "layer": "top",
    "modules-left": [
    "sway/workspaces", "sway/mode"
    ],
    "modules-center": [
    "sway/window"
    ],
    "modules-right": [
    "battery", "clock"
    ],

    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}"
    }
}